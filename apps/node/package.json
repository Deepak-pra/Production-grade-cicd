{
  "name": "shipfast-api-node",
  "version": "1.0.0",
  "description": "Node.js app for GitHub Actions CI/CD training demos",
  "main": "src/server.js",
  "bin": {
    "shipfast-node": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "build": "mkdir -p dist && npm pack --pack-destination dist/",
    "test": "jest --coverage",
    "lint": "eslint src/ --ext .js"
  },
  "files": [
    "src/**/*",
    "package.json"
  ],
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
